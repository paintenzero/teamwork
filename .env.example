# Redis connection used by @paintenzero/orchestra-bus. Defaults to this if unset.
REDIS_URL=redis://localhost:6379

# --- Redis auth (Phase 6, WS1) --------------------------------------------------
# Redis runs with an ACL file (redis/users.acl); no-auth connections are refused.
# The Bus authenticates with these (defaults shown keep the dev stack runnable).
# A deployment gives each role/agent its own scoped user — agents are namespaced so
# a compromised agent can't read another's control: or write another's presence:.
REDIS_USERNAME=dev
REDIS_PASSWORD=orchestra-dev
#   Per-role / per-agent users (see redis/users.acl); set these per process:
#   orchestrator: REDIS_USERNAME=orchestrator REDIS_PASSWORD=orchestra-orch
#   recorder:     REDIS_USERNAME=recorder     REDIS_PASSWORD=orchestra-rec
#   agent:        REDIS_USERNAME=<AGENT_ID>   REDIS_PASSWORD=<that agent's password>
# TLS to Redis: use rediss:// or REDIS_TLS=1, with a CA for the dev self-signed cert.
# Run TLS-only Redis with: docker compose -f docker-compose.yml -f docker-compose.tls.yml up -d
# REDIS_TLS=1
# REDIS_TLS_CA=redis/tls/ca.crt

# --- Gateway auth (Phase 6, WS2) ------------------------------------------------
# The orchestrator requires this token on every HTTP/WS request (Bearer header, or
# ?token= for browser WebSockets). The web build reads VITE_GATEWAY_TOKEN to match.
GATEWAY_TOKEN=dev-gateway-token
VITE_GATEWAY_TOKEN=dev-gateway-token

# --- Phase 6 reliability / limits (all have sane defaults) ----------------------
# GATEWAY_RATE_LIMIT_RPS=50     # WS9: max mutating gateway requests per second (429 over)
# MAX_RUN_MS=0                  # WS9: wall-clock cap on a root run (0 = no cap); delegated runs inherit
# OBS_MAXLEN=10000              # WS9: cap on a session's live observability stream
# DEDUPE_TTL_MS=86400000        # WS3: idempotency window for messageId dedupe (24h)
# RECLAIM_IDLE_MS=30000         # WS4: reclaim a request pending (un-acked) at least this long
# RECLAIM_EVERY_MS=10000        # WS4: how often a worker sweeps for stuck requests
# MAX_DELIVERIES=5              # WS4: delivery attempts before dead-lettering to req:<agent>:dlq

# Postgres — the recorder writes the queryable spine here (Phase 3).
DATABASE_URL=postgres://orchestra:orchestra@localhost:5432/orchestra

# External S3-compatible object storage (RustFS, MinIO, AWS S3, …) — the recorder
# archives full JSONL traces here, and agents store artifacts here (Phase 5); only
# references travel on the bus. The orchestrator reads both back (history + the
# artifact download proxy). The bucket is created on first use; the client uses
# path-style addressing. For a local one, run RustFS (see docker-compose.yml).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=orchestra
S3_ACCESS_KEY=orchestra
S3_SECRET_KEY=orchestra
# S3_REGION=us-east-1

# --- apps/agent identity & delegation -------------------------------------------
# AGENT_ID=agent-researcher
# AGENT_DESCRIPTION="A research assistant that ..."   # natural-language advertisement.
#   Every agent broadcasts this; every other agent injects the roster of these into
#   its system prompt each run, so the model picks who to delegate to by description.
# AGENT_CAPABILITIES=chat,research,clock      # optional tags (back-compat; discovery is by description)
# AGENT_SYSTEM_PROMPT=...                      # override the base system prompt (roster is appended)
# ROSTER_REFRESH_MS=60000                      # how often to refresh the peer roster (connect/disconnect)
# MAX_DELEGATION_DEPTH=4                        # cycle/depth guards (overridable per DelegateRequest budget)
# DELEGATE_TIMEOUT_MS=60000
# AGENT_LOG_PROMPT=1                            # debug: print the composed system prompt each run
#   Per-task sessions: an agent holds one conversation per task (ask_agent opens a task;
#   continue_task / close_task work it; a different task id is a different context).
# TASK_TTL_MS=1800000                          # drop a task's in-memory context after this idle (snapshot persists)
# MAX_TASKS=50                                 # cap on concurrently-held task contexts
# TASK_CONTEXT_TTL_MS=604800000                # retention of a task's snapshotted working memory in Redis (7d)
#   Token-free two-agent demo (see README): a worker, and a delegator that calls it BY ID.
#   AGENT_ID=agent-writer     AGENT_FAUX=1 AGENT_FAUX_ROLE=worker     AGENT_DESCRIPTION="Writes and edits short prose."
#   AGENT_ID=agent-researcher AGENT_FAUX=1 AGENT_DELEGATE_TO=agent-writer AGENT_DESCRIPTION="Researches and coordinates."
#   (AGENT_DELEGATE_TO is the target agent id the faux delegator calls via ask_agent.)
#   Artifact handoff demo (Phase 5): a producer that saves and a reader that reads —
#   AGENT_ID=agent-producer AGENT_FAUX=1 AGENT_FAUX_ROLE=producer
#   AGENT_ID=agent-reader   AGENT_FAUX=1 AGENT_FAUX_ROLE=reader

# --- apps/agent model selection (highest priority first) ------------------------
# 1. Custom OpenAI-compatible endpoint (vLLM, llama.cpp, LM Studio, a gateway, …).
#    Setting OPENAI_BASE_URL switches the agent to this model.
# OPENAI_BASE_URL=http://<model-host>:10000/v1
# OPENAI_API_KEY=not-used
# OPENAI_MODEL=qwen3.6-instruct-reasoning
#    Reasoning/thinking is opt-in and endpoint-specific. For qwen on llama.cpp:
# OPENAI_THINKING_FORMAT=qwen-chat-template   # how to ask the server to think
# OPENAI_THINKING_LEVEL=medium                # off|minimal|low|medium|high|xhigh
# OPENAI_CONTEXT_WINDOW=131072
# OPENAI_MAX_TOKENS=8192
#
# 2. Anthropic (used when OPENAI_BASE_URL is unset and this key is present).
# ANTHROPIC_API_KEY=sk-ant-...
#
# 3. Neither set → pi-ai's keyless `faux` provider (scripted, zero tokens).
#    Force faux even when a key is present with AGENT_FAUX=1.
