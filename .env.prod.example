# Production deployment config. Copy to `.env` next to docker-compose.prod.yml.
#
#   cp .env.prod.example .env
#   # edit the secrets below, then regenerate the matching Redis ACL:
#   node scripts/gen-acl.mjs
#   docker compose -f docker-compose.prod.yml --env-file .env up -d
#
# ⚠️  The defaults below match the committed redis/users.acl so the stack runs as-is
#     for a trial. CHANGE EVERY SECRET for a real deployment, then run gen-acl.mjs so
#     redis/users.acl matches these values (the apps authenticate with them).

# --- Images (override to pin a tag / use a different registry) -------------------
ORCHESTRA_IMAGE=paintezero/orchestra:latest
ORCHESTRA_WEB_IMAGE=paintezero/orchestra-web:latest

# --- Gateway (browser → orchestrator) -------------------------------------------
# nginx injects this token server-side; it never reaches the browser bundle.
GATEWAY_TOKEN=dev-gateway-token
GATEWAY_RATE_LIMIT_RPS=50
WEB_PORT=80

# --- Redis ACL passwords (MUST match redis/users.acl — run gen-acl.mjs after edits)
ORCHESTRA_ADMIN_PASSWORD=orchestra-admin
ORCHESTRA_DEV_PASSWORD=orchestra-dev
ORCHESTRA_ORCH_PASSWORD=orchestra-orch
ORCHESTRA_REC_PASSWORD=orchestra-rec
AGENT_RESEARCHER_PASSWORD=agent-researcher-pass
AGENT_WRITER_PASSWORD=agent-writer-pass
AGENT_PRODUCER_PASSWORD=agent-producer-pass
AGENT_READER_PASSWORD=agent-reader-pass
AGENT_ECHO_PASSWORD=agent-echo-pass

# --- Postgres -------------------------------------------------------------------
POSTGRES_USER=orchestra
POSTGRES_PASSWORD=orchestra
POSTGRES_DB=orchestra

# --- S3 (object storage) --------------------------------------------------------
# docker-compose.prod.yml bundles SeaweedFS (endpoint is internal, no S3_ENDPOINT
# needed). docker-compose.backend.yml instead uses an EXTERNAL S3-compatible
# service: set S3_ENDPOINT to it (RustFS, MinIO, AWS S3, …). Bucket defaults to
# "orchestra"; the apps use path-style addressing.
# S3_ENDPOINT=http://<host>:9000
S3_BUCKET=orchestra
S3_ACCESS_KEY=orchestra
S3_SECRET_KEY=orchestra

# --- Agent model (default: token-free faux) -------------------------------------
AGENT_FAUX=1
# For a real model, set AGENT_FAUX= (empty) and one of:
#   ANTHROPIC_API_KEY=sk-ant-...
# or an OpenAI-compatible endpoint:
#   OPENAI_BASE_URL=https://...
#   OPENAI_MODEL=...
#   OPENAI_API_KEY=...
ANTHROPIC_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_API_KEY=
# Per-tree wall-clock run budget in ms (0 = no cap).
MAX_RUN_MS=0
